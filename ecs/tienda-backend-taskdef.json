{
  "family": "tienda-backend",
  "executionRoleArn": "arn:aws:iam::860222871179:role/ecsTaskExecutionRole",
  "taskRoleArn": "arn:aws:iam::860222871179:role/ecsTaskExecutionRole",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "512",
  "memory": "1024",
  "containerDefinitions": [
    {
      "name": "backend",
      "image": "860222871179.dkr.ecr.us-east-1.amazonaws.com/tienda-backend:latest",
      "essential": true,
      "portMappings": [
        {
          "containerPort": 3001,
          "protocol": "tcp"
        }
      ],
      "environment": [
        { "name": "DB_HOST", "value": "svc-tienda-db.tienda.local" },
        { "name": "DB_USER", "value": "root" },
        { "name": "DB_PASSWORD", "value": "admin123" },
        { "name": "DB_NAME", "value": "tienda_perritos" },
        { "name": "DB_PORT", "value": "3306" }
      ],
      "healthCheck": {
        "command": ["CMD-SHELL", "curl -f http://localhost:3001/api/health || exit 1"],
        "interval": 30,
        "timeout": 5,
        "retries": 3,
        "startPeriod": 15
      },
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/tienda-backend",
          "awslogs-region": "us-east-1",
          "awslogs-stream-prefix": "ecs"
        }
      }
    }
  ]
}

{
  "family": "tienda-db",
  "executionRoleArn": "arn:aws:iam::860222871179:role/ecsTaskExecutionRole",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "256",
  "memory": "512",
  "containerDefinitions": [
    {
      "name": "mysql",
      "image": "860222871179.dkr.ecr.us-east-1.amazonaws.com/tienda-db:latest",
      "essential": true,
      "portMappings": [
        {
          "containerPort": 3306,
          "protocol": "tcp"
        }
      ],
      "environment": [
        { "name": "MYSQL_ROOT_PASSWORD", "value": "admin123" },
        { "name": "MYSQL_DATABASE", "value": "tienda_perritos" },
        { "name": "MYSQL_USER", "value": "alumno" },
        { "name": "MYSQL_PASSWORD", "value": "alumno123" }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/tienda-db",
          "awslogs-region": "us-east-1",
          "awslogs-stream-prefix": "ecs"
        }
      }
    }
  ]
}
